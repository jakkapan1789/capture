{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Capture",
  "version": "0.1.1",
  "identifier": "com.jakkapanpakeerat.capture",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Capture",
        "width": 1090,
        "height": 790,
        "minWidth": 1090,
        "minHeight": 670,
        "theme": "Dark",
        "backgroundColor": "#16171a"
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "\u00a9 2026 Jakkapan Pakeerat",
    "publisher": "Jakkapan Pakeerat"
  }
}
